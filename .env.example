# Etherr Contact Intake - Production Configuration
# Copy this file to .env and fill real values.

# Application
APP_ENV=production
APP_TIMEZONE=Europe/Zagreb

# Endpoint security
# Comma separated exact origins allowed to call the API.
# Example: https://etherr.hr,https://www.etherr.hr
ALLOWED_ORIGINS=

# Anti-spam rate limiting (per IP)
RATE_LIMIT_WINDOW_SEC=300
RATE_LIMIT_MAX_REQUESTS=8

# Cloudflare Turnstile (optional but recommended)
TURNSTILE_SECRET_KEY=
# If true and secret key exists, token is required.
TURNSTILE_ENFORCED=true

# Storage
# Keep this outside public web root in production if possible.
INTAKE_STORAGE_DIR=var
STORE_SUBMISSIONS=true

# Mail transport: smtp | mail
MAIL_TRANSPORT=smtp
MAIL_TO=info@etherr.hr
MAIL_FROM=noreply@etherr.hr
MAIL_FROM_NAME=Etherr Website

# SMTP (Exchange / Microsoft 365 typical)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT=15

# Optional debug (never enable on production)
SMTP_DEBUG=false
